// ============================================================
// PETSHOP GESTÃO — Schema do Banco de Dados
// Prisma ORM + PostgreSQL
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  owner
  manager
  employee
}

enum AppointmentStatus {
  scheduled
  confirmed
  in_progress
  completed
  cancelled
  no_show
}

enum AppointmentType {
  banho
  tosa
  banho_e_tosa
  hospedagem
  taxi_dog
  consulta
  outros
}

enum CashEntryType {
  income
  expense
}

enum PaymentMethod {
  cash
  pix
  credit_card
  debit_card
  transfer
}

enum PackageStatus {
  active
  expired
  completed
  cancelled
}

enum PetSize {
  pequeno
  medio
  grande
  gigante
}

// ============================================================
// USUÁRIOS (FUNCIONÁRIOS)
// ============================================================

model User {
  id            String   @id @default(uuid())
  name          String   @db.VarChar(100)
  email         String   @unique @db.VarChar(150)
  passwordHash  String   @map("password_hash")
  role          UserRole @default(employee)
  phone         String?  @db.VarChar(20)
  avatarUrl     String?  @map("avatar_url")
  isActive      Boolean  @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relações
  appointments      Appointment[]   @relation("EmployeeAppointments")
  createdAppointments Appointment[] @relation("CreatedByUser")
  cashEntries       CashEntry[]
  createdClients    Client[]
  soldPackages      ClientPackage[]

  @@map("users")
}

// ============================================================
// CLIENTES (TUTORES)
// ============================================================

model Client {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(100)
  phone       String   @db.VarChar(20)
  phone2      String?  @db.VarChar(20)
  email       String?  @db.VarChar(150)
  cpf         String?  @unique @db.VarChar(14)
  address     String?  @db.VarChar(300)
  notes       String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdById String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relações
  createdBy     User            @relation(fields: [createdById], references: [id])
  pets          Pet[]
  packages      ClientPackage[]
  appointments  Appointment[]

  @@map("clients")
}

// ============================================================
// PETS
// ============================================================

model Pet {
  id           String   @id @default(uuid())
  clientId     String   @map("client_id")
  name         String   @db.VarChar(80)
  species      String   @db.VarChar(40)  // cão, gato, etc.
  breed        String?  @db.VarChar(80)
  size         PetSize  @default(medio)
  weight       Decimal? @db.Decimal(5, 2)
  birthDate    DateTime? @map("birth_date")
  color        String?  @db.VarChar(60)
  microchip    String?  @unique @db.VarChar(20)
  vaccines     Json?    // lista de vacinas com datas
  allergies    String?  @db.Text
  observations String?  @db.Text
  photoUrl     String?  @map("photo_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relações
  client       Client        @relation(fields: [clientId], references: [id])
  appointments Appointment[]
  hotelStays   HotelStay[]

  @@map("pets")
}

// ============================================================
// SERVIÇOS
// ============================================================

model Service {
  id              String          @id @default(uuid())
  name            String          @db.VarChar(100)
  description     String?         @db.Text
  type            AppointmentType
  price           Decimal         @db.Decimal(10, 2)
  cost            Decimal         @default(0) @db.Decimal(10, 2)
  durationMinutes Int             @map("duration_minutes")
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relações
  appointments Appointment[]
  packageItems PackageService[]

  @@map("services")
}

// ============================================================
// AGENDAMENTOS
// ============================================================

model Appointment {
  id              String            @id @default(uuid())
  clientId        String            @map("client_id")
  petId           String?           @map("pet_id")
  serviceId       String?           @map("service_id")
  employeeId      String?           @map("employee_id")
  clientPackageId String?           @map("client_package_id")
  scheduledAt     DateTime          @default(now()) @map("scheduled_at")
  startedAt       DateTime?         @map("started_at")
  completedAt     DateTime?         @map("completed_at")
  status          AppointmentStatus @default(scheduled)
  type            AppointmentType   @default(banho)
  priceCharged    Decimal           @default(0) @db.Decimal(10, 2) @map("price_charged")
  discount        Decimal           @default(0) @db.Decimal(10, 2)
  paymentMethod   PaymentMethod?    @map("payment_method")
  notes           String?           @db.Text
  cancelledReason String?           @map("cancelled_reason") @db.Text
  createdById     String            @map("created_by")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  // Relações
  client        Client         @relation(fields: [clientId], references: [id])
  pet           Pet?           @relation(fields: [petId], references: [id])
  service       Service?       @relation(fields: [serviceId], references: [id])
  employee      User?          @relation("EmployeeAppointments", fields: [employeeId], references: [id])
  createdBy     User           @relation("CreatedByUser", fields: [createdById], references: [id])
  clientPackage ClientPackage? @relation(fields: [clientPackageId], references: [id])
  cashEntry     CashEntry?
  taxiDog       TaxiDog?

  @@index([scheduledAt])
  @@index([status])
  @@index([employeeId])
  @@index([clientId])
  @@map("appointments")
}

// ============================================================
// HOTEL — ESTADIAS
// ============================================================

model HotelStay {
  id           String    @id @default(uuid())
  petId        String    @map("pet_id")
  checkIn      DateTime  @map("check_in")
  checkOut     DateTime? @map("check_out")
  dailyRate    Decimal   @db.Decimal(10, 2) @map("daily_rate")
  totalDays    Int?      @map("total_days")
  totalAmount  Decimal?  @db.Decimal(10, 2) @map("total_amount")
  feedingNotes String?   @map("feeding_notes") @db.Text
  medications  String?   @db.Text
  status       String    @default("active") // active, checked_out
  notes        String?   @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  pet Pet @relation(fields: [petId], references: [id])

  @@map("hotel_stays")
}

// ============================================================
// TÁXI DOG
// ============================================================

model TaxiDog {
  id            String   @id @default(uuid())
  appointmentId String   @unique @map("appointment_id")
  pickupAddress String   @map("pickup_address") @db.VarChar(300)
  deliveryAddress String? @map("delivery_address") @db.VarChar(300)
  pickupTime    DateTime? @map("pickup_time")
  deliveryTime  DateTime? @map("delivery_time")
  distance      Decimal?  @db.Decimal(6, 2) // km
  price         Decimal   @db.Decimal(10, 2)
  notes         String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id])

  @@map("taxi_dog")
}

// ============================================================
// PACOTES
// ============================================================

model Package {
  id            String   @id @default(uuid())
  name          String   @db.VarChar(100)
  description   String?  @db.Text
  totalPrice    Decimal  @db.Decimal(10, 2) @map("total_price")
  totalSessions Int      @map("total_sessions")
  validityDays  Int      @map("validity_days")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  services      PackageService[]
  clientPackages ClientPackage[]

  @@map("packages")
}

model PackageService {
  id        String  @id @default(uuid())
  packageId String  @map("package_id")
  serviceId String  @map("service_id")
  quantity  Int     @default(1)

  package Package @relation(fields: [packageId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])

  @@map("package_services")
}

model ClientPackage {
  id               String        @id @default(uuid())
  clientId         String        @map("client_id")
  packageId        String        @map("package_id")
  soldById         String        @map("sold_by")
  purchasedAt      DateTime      @default(now()) @map("purchased_at")
  expiresAt        DateTime      @map("expires_at")
  sessionsTotal    Int           @map("sessions_total")
  sessionsUsed     Int           @default(0) @map("sessions_used")
  amountPaid       Decimal       @db.Decimal(10, 2) @map("amount_paid")
  status           PackageStatus @default(active)
  notes            String?       @db.Text
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  client       Client        @relation(fields: [clientId], references: [id])
  package      Package       @relation(fields: [packageId], references: [id])
  soldBy       User          @relation(fields: [soldById], references: [id])
  appointments Appointment[]

  @@map("client_packages")
}

// ============================================================
// FINANCEIRO — CAIXA
// ============================================================

model CashEntry {
  id            String        @id @default(uuid())
  type          CashEntryType
  amount        Decimal       @db.Decimal(10, 2)
  description   String        @db.VarChar(200)
  category      String        @db.VarChar(80)
  paymentMethod PaymentMethod @map("payment_method")
  appointmentId String?       @unique @map("appointment_id")
  registeredById String       @map("registered_by")
  referenceDate DateTime      @map("reference_date") @db.Date
  dueDate       DateTime?     @map("due_date") @db.Date
  isPaid        Boolean       @default(true) @map("is_paid")
  notes         String?       @db.Text
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  appointment  Appointment? @relation(fields: [appointmentId], references: [id])
  registeredBy User         @relation(fields: [registeredById], references: [id])

  @@index([referenceDate])
  @@index([type])
  @@map("cash_entries")
}
