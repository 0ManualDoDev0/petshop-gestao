# ============================================================
# PETSHOP GESTÃO — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# === BANCO DE DADOS ===
# Formato: postgresql://USUARIO:SENHA@HOST:PORT/NOME_DB
DATABASE_URL="postgresql://postgres:suasenha@localhost:5432/petshop_gestao"

# === JWT ===
JWT_SECRET="troque-isso-por-uma-string-segura-longa-e-aleatoria"
JWT_REFRESH_SECRET="outro-secret-diferente-para-refresh-token"

# === APP ===
PORT=3001
NODE_ENV=development

# === WEB APP URL (para CORS) ===
WEB_URL="http://localhost:3000"

# ============================================================
# PARA PRODUÇÃO (Railway, Render, etc.)
# ============================================================
# DATABASE_URL → fornecida automaticamente pelo provedor
# JWT_SECRET   → gere com: node -e "require('crypto').randomBytes(64).toString('hex')"
# NODE_ENV=production
# PORT=3001 (ou deixe o provedor definir)
